{% extends 'base.html' %}
{% block title %}Laisser un avis{% endblock %}
{% block content %}
<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="mb-8">
    <a href="{% url 'contracts:detail' contract.pk %}" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-brand-600 mb-4 transition-colors">
      <i data-lucide="arrow-left" class="w-4 h-4"></i> Retour au contrat
    </a>
    <h1 class="font-display text-3xl font-700">Évaluer la collaboration</h1>
    <p class="text-gray-500 mt-1">Votre avis aide la communauté FreelanceHT</p>
  </div>

  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
    <!-- Project info -->
    <div class="flex items-center gap-4 mb-8 pb-6 border-b border-gray-100">
      <div class="w-12 h-12 rounded-2xl bg-brand-50 flex items-center justify-center">
        <i data-lucide="briefcase" class="w-6 h-6 text-brand-600"></i>
      </div>
      <div>
        <p class="font-semibold text-gray-900">{{ contract.project.title }}</p>
        <p class="text-sm text-gray-500">Contrat terminé</p>
      </div>
    </div>

    <form method="post" class="space-y-7">
      {% csrf_token %}

      <!-- Global rating -->
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-3">Note globale</label>
        <div class="flex gap-2" id="star-rating">
          {% for i in "12345" %}
          <button type="button" onclick="setRating({{ forloop.counter }})"
            class="star-btn w-10 h-10 rounded-xl border-2 border-gray-200 flex items-center justify-center transition-all hover:border-gold-400 hover:bg-amber-50"
            data-value="{{ forloop.counter }}">
            <i data-lucide="star" class="w-5 h-5 text-gray-300"></i>
          </button>
          {% endfor %}
        </div>
        <input type="hidden" name="rating" id="rating-input" value="5">
      </div>

      <!-- Sub-scores -->
      <div class="space-y-4">
        <label class="block text-sm font-semibold text-gray-700">Critères détaillés</label>
      <!--  {% for label, name, icon in "Communication,communication,message-circle|Qualité du travail,quality,award|Respect des délais,deadline,clock"|split:'|' %}
        {% endfor %} -->

        <div class="grid grid-cols-3 gap-3">
          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100 text-center">
            <i data-lucide="message-circle" class="w-5 h-5 mx-auto mb-2 text-brand-500"></i>
            <p class="text-xs font-semibold text-gray-600 mb-2">Communication</p>
            <select name="communication" class="w-full text-sm rounded-lg border border-gray-200 py-1.5 px-2 text-center focus:ring-2 focus:ring-brand-500">
              {% for i in "54321" %}<option value="{{ i }}">{{ i }}/5</option>{% endfor %}
            </select>
          </div>
          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100 text-center">
            <i data-lucide="award" class="w-5 h-5 mx-auto mb-2 text-brand-500"></i>
            <p class="text-xs font-semibold text-gray-600 mb-2">Qualité</p>
            <select name="quality" class="w-full text-sm rounded-lg border border-gray-200 py-1.5 px-2 text-center focus:ring-2 focus:ring-brand-500">
              {% for i in "54321" %}<option value="{{ i }}">{{ i }}/5</option>{% endfor %}
            </select>
          </div>
          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100 text-center">
            <i data-lucide="clock" class="w-5 h-5 mx-auto mb-2 text-brand-500"></i>
            <p class="text-xs font-semibold text-gray-600 mb-2">Délais</p>
            <select name="deadline" class="w-full text-sm rounded-lg border border-gray-200 py-1.5 px-2 text-center focus:ring-2 focus:ring-brand-500">
              {% for i in "54321" %}<option value="{{ i }}">{{ i }}/5</option>{% endfor %}
            </select>
          </div>
        </div>
      </div>

      <!-- Comment -->
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Commentaire</label>
        <textarea name="comment" rows="4" placeholder="Partagez votre expérience avec cette collaboration..."
          class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none"></textarea>
      </div>

      <button type="submit" class="w-full btn-primary text-white font-semibold py-3.5 rounded-xl shadow-md flex items-center justify-center gap-2">
        <i data-lucide="send" class="w-4 h-4"></i> Publier mon avis
      </button>
    </form>
  </div>
</div>

<script>
function setRating(val) {
  document.getElementById('rating-input').value = val;
  document.querySelectorAll('.star-btn').forEach((btn, idx) => {
    const icon = btn.querySelector('i');
    if (idx < val) {
      btn.classList.add('border-gold-400', 'bg-amber-50');
      btn.classList.remove('border-gray-200');
      icon.classList.add('text-amber-400', 'fill-current');
      icon.classList.remove('text-gray-300');
    } else {
      btn.classList.remove('border-gold-400', 'bg-amber-50');
      btn.classList.add('border-gray-200');
      icon.classList.remove('text-amber-400', 'fill-current');
      icon.classList.add('text-gray-300');
    }
  });
}
// Default 5 stars
setRating(5);
</script>
{% endblock %}
