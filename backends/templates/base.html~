<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{% block title %}FreelanceHT{% endblock %} — La plateforme freelance haïtienne</title>
  <script src="{% static 'js/browser@4.js'%}"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50:  '#f0fdf9',
              100: '#ccfbef',
              200: '#99f6e0',
              300: '#5eead4',
              400: '#2dd4bf',
              500: '#14b8a6',
              600: '#0d9488',
              700: '#0f766e',
              800: '#115e59',
              900: '#134e4a',
            },
            gold: {
              400: '#fbbf24',
              500: '#f59e0b',
            }
          },
          fontFamily: {
            display: ['"Syne"', 'sans-serif'],
            body: ['"DM Sans"', 'sans-serif'],
          },
          animation: {
            'fade-in': 'fadeIn 0.4s ease-out',
            'slide-up': 'slideUp 0.5s ease-out',
          },
          keyframes: {
            fadeIn: { from: { opacity: 0 }, to: { opacity: 1 } },
            slideUp: { from: { opacity: 0, transform: 'translateY(16px)' }, to: { opacity: 1, transform: 'translateY(0)' } },
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <style>
    body { font-family: 'DM Sans', sans-serif; }
    h1,h2,h3,h4,h5 { font-family: 'Syne', sans-serif; }
    .nav-link { transition: color .2s, border-color .2s; }
    .card-hover { transition: transform .2s, box-shadow .2s; }
    .card-hover:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,.1); }
    .btn-primary { background: linear-gradient(135deg, #0d9488, #14b8a6); transition: opacity .2s, transform .2s; }
    .btn-primary:hover { opacity: .92; transform: translateY(-1px); }
    .skill-badge { font-size: .7rem; letter-spacing: .04em; text-transform: uppercase; font-weight: 600; }
    .star-filled { color: #f59e0b; }
    .star-empty { color: #d1d5db; }
    input:focus, textarea:focus, select:focus { outline: none; }
    .gradient-text { background: linear-gradient(135deg, #0d9488, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .pattern-bg { background-image: radial-gradient(circle at 2px 2px, #e5e7eb 1px, transparent 0); background-size: 28px 28px; }
    .glass { background: rgba(255,255,255,.85); backdrop-filter: blur(12px); }
  </style>
  {% block extra_head %}{% endblock %}
</head>
<body class="bg-gray-50 text-gray-900 antialiased">

<!-- NAVBAR -->
<nav class="sticky top-0 z-50 glass border-b border-gray-200/60 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="{% url 'core:home' %}" class="flex items-center gap-2 group">
        <div class="w-9 h-9 rounded-xl btn-primary flex items-center justify-center shadow-md">
          <i data-lucide="zap" class="w-5 h-5 text-white"></i>
        </div>
        <span class="font-display font-800 text-xl tracking-tight">Freelance<span class="text-brand-600">HT</span></span>
      </a>

      <!-- Nav links -->
      <div class="hidden md:flex items-center gap-6">
        <a href="{% url 'freelancers:list' %}" class="nav-link text-sm font-medium text-gray-600 hover:text-brand-700 flex items-center gap-1.5">
          <i data-lucide="users" class="w-4 h-4"></i> Freelancers
        </a>
        <a href="{% url 'projects:list' %}" class="nav-link text-sm font-medium text-gray-600 hover:text-brand-700 flex items-center gap-1.5">
          <i data-lucide="briefcase" class="w-4 h-4"></i> Projets
        </a>
      </div>

      <!-- Auth -->
      <div class="flex items-center gap-3">
        {% if user.is_authenticated %}
          <a href="{% url 'messaging:list' %}" class="relative p-2 rounded-lg hover:bg-gray-100 text-gray-500 hover:text-brand-700 transition-colors">
            <i data-lucide="message-circle" class="w-5 h-5"></i>
          </a>
          <div class="relative" x-data="{ open: false }">
            <a href="{% url 'accounts:dashboard' %}" class="flex items-center gap-2 px-3 py-2 rounded-xl hover:bg-gray-100 transition-colors text-sm font-medium text-gray-700">
              <div class="w-8 h-8 rounded-full bg-brand-100 border-2 border-brand-300 flex items-center justify-center text-brand-700 font-display font-700 text-sm">
                {{ user.first_name|first|upper }}{{ user.last_name|first|upper }}
              </div>
              <span class="hidden sm:block">{{ user.first_name }}</span>
              <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
            </a>
          </div>
          <a href="{% url 'accounts:logout' %}" class="text-sm text-gray-500 hover:text-red-500 transition-colors px-2 py-1 rounded-lg hover:bg-red-50">
            <i data-lucide="log-out" class="w-4 h-4 inline"></i>
          </a>
        {% else %}
          <a href="{% url 'accounts:login' %}" class="text-sm font-medium text-gray-600 hover:text-brand-700 px-4 py-2 rounded-xl hover:bg-brand-50 transition-colors">Connexion</a>
          <a href="{% url 'accounts:register' %}" class="text-sm font-semibold text-white px-4 py-2 rounded-xl btn-primary shadow-sm">Inscription</a>
        {% endif %}
      </div>
    </div>
  </div>
</nav>

<!-- FLASH MESSAGES -->
{% if messages %}
<div class="fixed top-20 right-4 z-50 flex flex-col gap-2 animate-fade-in" id="flash-messages">
  {% for message in messages %}
  <div class="flex items-center gap-3 px-4 py-3 rounded-xl shadow-lg text-sm font-medium border max-w-sm
    {% if message.tags == 'success' %}bg-green-50 border-green-200 text-green-800
    {% elif message.tags == 'error' %}bg-red-50 border-red-200 text-red-800
    {% elif message.tags == 'warning' %}bg-amber-50 border-amber-200 text-amber-800
    {% else %}bg-blue-50 border-blue-200 text-blue-800{% endif %}">
    {% if message.tags == 'success' %}<i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
    {% elif message.tags == 'error' %}<i data-lucide="x-circle" class="w-4 h-4 flex-shrink-0"></i>
    {% elif message.tags == 'warning' %}<i data-lucide="alert-triangle" class="w-4 h-4 flex-shrink-0"></i>
    {% else %}<i data-lucide="info" class="w-4 h-4 flex-shrink-0"></i>{% endif %}
    {{ message }}
  </div>
  {% endfor %}
</div>
<script>setTimeout(() => { const el = document.getElementById('flash-messages'); if(el) el.style.display='none'; }, 5000);</script>
{% endif %}

<!-- PAGE CONTENT -->
<main class="animate-fade-in">
  {% block content %}{% endblock %}
</main>

<!-- FOOTER -->
<footer class="bg-gray-900 text-gray-400 mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg btn-primary flex items-center justify-center">
            <i data-lucide="zap" class="w-4 h-4 text-white"></i>
          </div>
          <span class="font-display text-white text-lg font-700">FreelanceHT</span>
        </div>
        <p class="text-sm leading-relaxed max-w-xs">La première plateforme freelance dédiée aux talents haïtiens. Connectez-vous, collaborez, et grandissez ensemble.</p>
        <p class="text-xs mt-6 text-gray-600">© 2025 FreelanceHT. Tous droits réservés.</p>
      </div>
      <div>
        <h4 class="text-white text-sm font-semibold mb-4 font-display">Plateforme</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="{% url 'freelancers:list' %}" class="hover:text-brand-400 transition-colors">Trouver un freelancer</a></li>
          <li><a href="{% url 'projects:list' %}" class="hover:text-brand-400 transition-colors">Voir les projets</a></li>
          <li><a href="{% url 'accounts:register' %}" class="hover:text-brand-400 transition-colors">Devenir freelancer</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white text-sm font-semibold mb-4 font-display">Contact</h4>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2"><i data-lucide="mail" class="w-3.5 h-3.5"></i> contact@freelanceht.com</li>
          <li class="flex items-center gap-2"><i data-lucide="map-pin" class="w-3.5 h-3.5"></i> Port-au-Prince, Haïti</li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<script>lucide.createIcons();</script>
{% block extra_scripts %}{% endblock %}
</body>
</html>
